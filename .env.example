# --- Site URL (optional) — canonical origin for Open Graph / metadataBase / PWA manifest id ---
# Production example:
# NEXT_PUBLIC_SITE_URL=https://void-wars-game.vercel.app
#
# --- Browser (Vercel / Next): void realtime + social chat ---
# Production: deploy `server/void-realtime/wsServer.ts` separately, then set the public WSS URL:
# NEXT_PUBLIC_VOID_WS_URL=wss://your-realtime-host.example.com
#
# Optional overrides when not using NEXT_PUBLIC_VOID_WS_URL (local/dev):
# NEXT_PUBLIC_VOID_WS_HOST=localhost
# NEXT_PUBLIC_VOID_WS_PORT=3002

# --- Void realtime server (Fly / Railway / VPS / docker) ---
# VOID_WS_PORT=3002
# VOID_WS_HOST=0.0.0.0
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/void_wars
